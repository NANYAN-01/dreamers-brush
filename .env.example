# MySQL 数据库配置
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_mysql_password
DB_NAME=dreamers_brush

# 阿里云 DashScope API 配置
DASHSCOPE_API_KEY=your_api_key_here

# 可选模型（修改下面这行即可切换模型）：
# - qwen-image-2.0-pro-2026-04-22  （通义千问 2.0 Pro，高质量，推荐）
# - wan2.7-image                   （万相 2.7，艺术风格）
# - wan2.7-image-pro               （万相 2.7 Pro，专业版）
DASHSCOPE_DEFAULT_MODEL=qwen-image-2.0-pro-2026-04-22

# 服务器端口
PORT=3001
